<UserControl x:Class="LibraryManagement.UI.BorrowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== TITLE ===== -->
        <TextBlock Text="QUẢN LÝ MƯỢN SÁCH"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- ===== FORM ===== -->
        <Border Grid.Row="1"
                Background="White"
                Padding="15"
                CornerRadius="10"
                Margin="0,0,0,20">

            <StackPanel>

                <WrapPanel Margin="0,0,0,10">

                    <StackPanel x:Name="spReader" Margin="10">
                        <TextBlock Text="Người đọc" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbReader"
                          Width="200"
                          Height="30"/>     
                    </StackPanel>

                    <StackPanel Margin="10">
                        <TextBlock Text="Sách"/>
                        <ComboBox x:Name="cbBook"
                                  Width="200"
                                  Height="30"/>
                    </StackPanel>

                    <StackPanel Margin="10">
                        <TextBlock Text="Hạn trả"/>
                        <DatePicker x:Name="dpDueDate"
                                    Width="150"
                                    Height="30"/>
                    </StackPanel>

                </WrapPanel>

                <WrapPanel HorizontalAlignment="Center" Margin="0,10">

                    <Button Content="MƯỢN SÁCH"
                            Width="120"
                            Height="35"
                            Margin="10"
                            Background="#4CAF50"
                            Foreground="White"
                            Click="Borrow_Click"/>

                    <Button Content="TRẢ SÁCH"
                            Width="120"
                            Height="35"
                            Margin="10"
                            Background="#2196F3"
                            Foreground="White"
                            Click="Return_Click"/>

                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- ===== SEARCH + DATAGRID ===== -->
        <StackPanel Grid.Row="2">

            <TextBox x:Name="txtSearch"
                     Width="300"
                     Height="30"
                     Margin="0,0,0,10"
                     Text="Tìm theo tên người đọc hoặc sách..."
                     Foreground="Gray"
                     GotFocus="txtSearch_GotFocus"
                     LostFocus="txtSearch_LostFocus"
                     TextChanged="txtSearch_TextChanged"/>

            <DataGrid x:Name="dgBorrow"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          Background="White">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Sách"
                            Binding="{Binding BookTitle}"
                            Width="*"/>

                    <DataGridTextColumn x:Name="colReader"
                            Header="Người đọc"
                            Binding="{Binding ReaderName}" 
                                        Width="*"/>

                    <DataGridTextColumn Header="Ngày mượn"
                            Binding="{Binding BorrowDate}" 
                                        Width="*"/>

                    <DataGridTextColumn Header="Hạn trả"
                            Binding="{Binding DueDate}" 
                                        Width="*"/>

                    <DataGridTextColumn Header="Trạng thái"
                            Binding="{Binding Status}" 
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

    </Grid>
</UserControl>