<UserControl x:Class="LibraryManagement.UI.BookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="15" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A8A" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="📖" FontSize="30" Foreground="White" Margin="0,0,10,0"/>
                    <TextBlock Text="QUẢN LÝ SÁCH" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="20" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tiêu Đề" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTitle" Height="35" Background="#F1F5F9" BorderThickness="0" Padding="8,5" Margin="0,0,0,15"/>

                            <TextBlock Text="Tác Giả" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtAuthor" Height="35" Background="#F1F5F9" BorderThickness="0" Padding="8,5" Margin="0,0,0,15"/>

                            <TextBlock Text="Thể Loại" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtCategory" Height="35" Background="#F1F5F9" BorderThickness="0" Padding="8,5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Số Lượng" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtQuantity" Height="35" Background="#F1F5F9" BorderThickness="0" Padding="8,5" Margin="0,0,0,15"/>

                            <TextBlock Text="Tìm Kiếm" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtSearch" Height="35" Background="#F1F5F9" BorderThickness="0" Padding="8,5"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Button x:Name="btnAdd" Content="+ Thêm" Click="btnAdd_Click" Width="100" Height="38" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                        <Button x:Name="btnUpdate" Content="✎ Sửa" Click="btnUpdate_Click" Width="100" Height="38" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                        <Button x:Name="btnDelete" Content="🗑 Xóa" Click="btnDelete_Click" Width="100" Height="38" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                        <Button x:Name="btnSearch" Content="🔍 Tìm Kiếm" Click="btnSearch_Click" Width="100" Height="38" Background="#8B5CF6" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                        <Button x:Name="btnRefresh" Content="🔄 Tải Lại" Click="btnRefresh_Click" Width="100" Height="38" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Cursor="Hand"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="dgBooks" Height="250"
                              AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0.5" BorderBrush="#DDD"
                              RowHeight="40" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              SelectionChanged="dgBooks_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="60"/>
                            <DataGridTextColumn Header="Tiêu Đề" Binding="{Binding Title}" Width="2*"/>
                            <DataGridTextColumn Header="Tác Giả" Binding="{Binding Author}" Width="1.5*"/>
                            <DataGridTextColumn Header="Thể Loại" Binding="{Binding Category}" Width="1*"/>
                            <DataGridTextColumn Header="Số Lượng" Binding="{Binding Quantity}" Width="80"/>
                            <DataGridTextColumn Header="Sẵn Có" Binding="{Binding AvailableQuantity}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>