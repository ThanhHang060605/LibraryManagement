<UserControl x:Class="LibraryManagement.UI.BookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

	<Grid Margin="30">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="30"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="30"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
		<Border CornerRadius="15" Padding="25">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#1E3A8A" Offset="0"/>
					<GradientStop Color="#2563EB" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>

			<TextBlock Text="📚 QUẢN LÝ SÁCH"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
		</Border>

		<!-- FORM + BUTTON -->
		<Border Grid.Row="2"
                Background="White"
                CornerRadius="20"
                Padding="30">

			<Border.Effect>
				<DropShadowEffect BlurRadius="20"
                                  ShadowDepth="5"
                                  Opacity="0.15"/>
			</Border.Effect>

			<Grid>

				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="30"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- FORM -->
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition/>
					</Grid.ColumnDefinitions>

					<StackPanel Margin="15">
						<TextBlock Text="Title"/>
						<TextBox x:Name="txtTitle"/>

						<TextBlock Text="Author" Margin="0,10,0,0"/>
						<TextBox x:Name="txtAuthor"/>

						<TextBlock Text="Category" Margin="0,10,0,0"/>
						<TextBox x:Name="txtCategory"/>
					</StackPanel>

					<StackPanel Grid.Column="1" Margin="15">
						<TextBlock Text="Quantity"/>
						<TextBox x:Name="txtQuantity"/>

						<TextBlock Text="Search" Margin="0,10,0,0"/>
						<TextBox x:Name="txtSearch"/>
					</StackPanel>
				</Grid>

				<!-- BUTTONS -->
				<StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

					<Button x:Name="btnAdd"
                            Content="Add"
                            Click="btnAdd_Click"
                            Width="100"
                            Margin="10"/>

					<Button x:Name="btnUpdate"
                            Content="Update"
                            Click="btnUpdate_Click"
                            Width="100"
                            Margin="10"/>

					<Button x:Name="btnDelete"
                            Content="Delete"
                            Click="btnDelete_Click"
                            Width="100"
                            Margin="10"/>

					<Button Content="Search"
                            Click="btnSearch_Click"
                            Width="100"
                            Margin="10"/>
				</StackPanel>

			</Grid>
		</Border>

		<!-- DATAGRID -->
		<DataGrid Grid.Row="4"
                  x:Name="dgBooks"
                  AutoGenerateColumns="False"
                  SelectionChanged="dgBooks_SelectionChanged">

			<DataGrid.Columns>
				<DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="80"/>
				<DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
				<DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="150"/>
				<DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
				<DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
				<DataGridTextColumn Header="Available" Binding="{Binding AvailableQuantity}" Width="*"/>
			</DataGrid.Columns>

		</DataGrid>

	</Grid>
</UserControl>